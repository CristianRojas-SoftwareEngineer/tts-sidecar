#!/usr/bin/env python3
"""
Entry point de tts-sidecar.

Modo compilado (PyInstaller --onedir): los paquetes están embebidos por
PyInstaller y sys.path lo gestiona el intérprete embebido automáticamente.
Modo desarrollo: se añade el directorio src/ del proyecto a sys.path.

El bootstrap pre-import (warnings, env vars, logging, mock de pkg_resources)
corre dentro de tts_sidecar.cli al importarlo, no aquí: así se aplica también
al entry point generado por pip/uv y a `python -m tts_sidecar`.
"""

import sys
from pathlib import Path

if getattr(sys, 'frozen', False):
    pass
else:
    _script_dir = Path(__file__).parent.resolve()
    _project_root = _script_dir.parent
    _src_path = _project_root / "src"
    if _src_path.exists():
        sys.path.insert(0, str(_src_path))

from tts_sidecar.cli import main

if __name__ == "__main__":
    main()
