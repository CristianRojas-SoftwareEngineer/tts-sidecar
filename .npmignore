# package.json solo expone los scripts `npm run build-*`; el paquete no publica
# código fuente a npm. Estas reglas excluyen lo que no debe empaquetarse.

# Código fuente y tests Python
src/
tests/

# Documentación y CI
docs/
.circleci/

# Artefactos de build
dist/
dist_test/
__pycache__/
*.pyc
*.egg-info/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
